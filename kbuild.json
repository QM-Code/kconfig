{
	"project": {
		"title": "Karma JSON Config Storage SDK",
		"id": "kconfig"
	},
	"git": {
		"url": "https://github.com/QM-Code/kconfig",
		"auth": "git@github.com:QM-Code/kconfig.git"
	},
	"cmake": {
		"minimum_version": "3.20",
		"configure_by_default": true,
		"sdk": {
			"package_name": "KConfigSDK"
		},
		"dependencies": {
			"KcliSDK": {
				"prefix": "../kcli/build/{version}/sdk"
			},
			"KTraceSDK": {
				"prefix": "../ktrace/build/{version}/sdk"
			}
		}
	},
	"vcpkg": {
		"dependencies": [
			"spdlog",
			"nlohmann-json"
		]
	},
	"build": {
		"defaults": {
			"demos": [
				"compile"
			]
		}
	}
}
